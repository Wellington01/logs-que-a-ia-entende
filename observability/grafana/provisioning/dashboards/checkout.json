{
  "uid": "checkout-obs",
  "title": "Checkout — Observabilidade",
  "tags": ["demo", "checkout", "logs", "ia"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Taxa de erro (5m)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "orange", "value": 0.05 },
            { "color": "red", "value": 0.2 }
          ] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [ { "datasource": { "type": "loki", "uid": "loki" }, "editorMode": "code", "queryType": "range", "refId": "A",
        "expr": "sum(rate({service_name=\"checkout-service\"} | outcome=\"error\" [5m])) / sum(rate({service_name=\"checkout-service\"} [5m]))" } ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Requisições (5m)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "graphMode": "area" },
      "targets": [ { "datasource": { "type": "loki", "uid": "loki" }, "editorMode": "code", "queryType": "range", "refId": "A",
        "expr": "sum(count_over_time({service_name=\"checkout-service\"} | event=~\".+\" [5m]))" } ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Erros (5m)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [ { "datasource": { "type": "loki", "uid": "loki" }, "editorMode": "code", "queryType": "range", "refId": "A",
        "expr": "sum(count_over_time({service_name=\"checkout-service\"} | outcome=\"error\" [5m]))" } ]
    },
    {
      "id": 4,
      "type": "piechart",
      "title": "Eventos por tipo",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "options": { "legend": { "displayMode": "list", "placement": "right" }, "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [ { "datasource": { "type": "loki", "uid": "loki" }, "editorMode": "code", "queryType": "instant", "refId": "A", "legendFormat": "{{event}}",
        "expr": "sum by (event) (count_over_time({service_name=\"checkout-service\"} | event=~\".+\" [$__range]))" } ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Erros por minuto (o pico de incidente)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60, "lineWidth": 1 }, "color": { "mode": "fixed", "fixedColor": "red" } } },
      "targets": [ { "datasource": { "type": "loki", "uid": "loki" }, "editorMode": "code", "queryType": "range", "refId": "A", "legendFormat": "erros/min",
        "expr": "sum(count_over_time({service_name=\"checkout-service\"} | outcome=\"error\" [1m]))" } ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Erros por código",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 70, "stacking": { "mode": "normal" } } } },
      "targets": [ { "datasource": { "type": "loki", "uid": "loki" }, "editorMode": "code", "queryType": "range", "refId": "A", "legendFormat": "{{error_code}}",
        "expr": "sum by (error_code) (count_over_time({service_name=\"checkout-service\"} | error_code=~\".+\" [1m]))" } ]
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Erros recentes (clica → trace_id leva pro Tempo)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 12 },
      "options": { "showTime": true, "wrapLogMessage": true, "enableLogDetails": true, "sortOrder": "Descending", "dedupStrategy": "none" },
      "targets": [ { "datasource": { "type": "loki", "uid": "loki" }, "editorMode": "code", "queryType": "range", "refId": "A",
        "expr": "{service_name=\"checkout-service\"} | outcome=\"error\"" } ]
    }
  ]
}
